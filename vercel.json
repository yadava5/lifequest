{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build:packages && npm run -w apps/api prisma:generate && npm run -w apps/api build && npm run -w apps/desktop build",
  "outputDirectory": "apps/desktop/dist",
  "functions": {
    "api/index.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/system-card", "destination": "/system-card/index.html" },
    { "source": "/((?!api|system-card).*)", "destination": "/index.html" }
  ]
}
