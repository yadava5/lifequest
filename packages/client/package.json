{
  "name": "@lifequest/client",
  "version": "0.1.0",
  "description": "HTTP client helpers for the LifeQuest API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --watch --format esm --dts"
  },
  "dependencies": {
    "@lifequest/schemas": "file:../schemas",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.6.3"
  }
}
