{
  "name": "lifequest",
  "private": true,
  "description": "LifeQuest monorepo for desktop, API, and shared packages",
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs"
  ],
  "scripts": {
    "dev:desktop": "pnpm -C apps/desktop dev",
    "dev:api": "pnpm -C apps/api dev",
    "dev": "pnpm -C apps/desktop dev",
    "build:desktop": "pnpm -C apps/desktop build",
    "build:api": "pnpm -C apps/api build",
    "lint:desktop": "pnpm -C apps/desktop lint",
    "lint:api": "pnpm -C apps/api lint",
    "test:api": "pnpm -C apps/api test"
  }
}
