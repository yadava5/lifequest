{
  "name": "lifequest",
  "private": true,
  "description": "LifeQuest monorepo for desktop, API, and shared packages",
  "license": "MIT",
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs"
  ],
  "dependencies": {
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.1",
    "@nestjs/platform-fastify": "^11.1.1",
    "@prisma/client": "^6.0.1",
    "argon2": "^0.41.1",
    "fastify": "^4.28.1",
    "pino": "^9.4.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "scripts": {
    "dev:desktop": "npm run -w apps/desktop dev",
    "dev:api": "npm run -w apps/api dev",
    "dev": "npm run -w apps/desktop dev",
    "build:desktop": "npm run -w apps/desktop build",
    "build:api": "npm run -w apps/api build",
    "build:packages": "npm run -w packages/schemas build && npm run -w packages/client build",
    "lint:desktop": "npm run -w apps/desktop lint",
    "lint:api": "npm run -w apps/api lint",
    "test:api": "npm run -w apps/api test"
  }
}
